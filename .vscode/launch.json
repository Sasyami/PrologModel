{
    // See https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run generate_solutions.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/generate_solutions.py",
            "console": "integratedTerminal",
            "args": [
                "--tasks", "${workspaceFolder}/benchmark/tasks_swipl.jsonl",
                "--out-dir", "${workspaceFolder}/outputs/solutions",
                "--model", "qwen2.5-coder:1.5b",
                "--overwrite"
            ]
        },
        {
            "name": "Run eval_runner.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/eval_runner.py",
            "console": "integratedTerminal",
            "args": [
                "--tasks", "${workspaceFolder}/benchmark/tasks_swipl.jsonl",
                "--mode", "solutions",
                "--solutions-dir", "${workspaceFolder}/outputs/solutions"
            ]
        },
        {
            "name": "Run parse.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/data/parse.py",
            "console": "integratedTerminal"
        }
    ]
}
